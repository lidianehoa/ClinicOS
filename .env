# Chave Gemini removida do cliente — guardada no Firebase Secret Manager.
# Para configurar: firebase functions:secrets:set GEMINI_API_KEY

# ── Tenant Configuration ──────────────────────────────────────────────────────
# Unique identifier for this clinic instance
# Use lowercase letters, numbers and underscores only
VITE_APP_TENANT_ID=clinicos_demo

# ── Firebase Configuration ────────────────────────────────────────────────────
# Get these values from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── WhatsApp Configuration (Optional) ─────────────────────────────────────────
# Evolution API credentials for WhatsApp notifications
# Configure in app: Settings → Integrations
VITE_EVOLUTION_URL=
VITE_EVOLUTION_KEY=
VITE_EVOLUTION_INSTANCE=clinicos
