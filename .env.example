# ══════════════════════════════════════════════════════════════════════════════
# ClinicOS — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Tenant Configuration ──────────────────────────────────────────────────────
# Unique identifier for this clinic instance.
# All Firestore data is namespaced under this ID — changing it creates a
# completely isolated database. Use lowercase letters, numbers and underscores.
# Examples: my_clinic, downtown_vet, smile_dental, fisio_center
VITE_APP_TENANT_ID=your_clinic_id

# ── Firebase Configuration ────────────────────────────────────────────────────
# Get these values from your Firebase Console:
# console.firebase.google.com → Project Settings → Your Apps → Web App
# → SDK setup and configuration → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── WhatsApp Configuration (Optional) ─────────────────────────────────────────
# Evolution API credentials for automated WhatsApp notifications.
# If not set, the WhatsApp integration will be disabled.
# Configure after deployment: Settings → Integrations → WhatsApp (Evolution API)
VITE_EVOLUTION_URL=
VITE_EVOLUTION_KEY=
VITE_EVOLUTION_INSTANCE=clinicos
